---
import Analytics from '@vercel/analytics/astro';
import {
  events,
  meta,
  computeStatus,
  BUILD_DATE,
  fmtDate,
  PROVIDERS,
} from '../lib/data';

const now = new Date();
const rows = events.map((e) => ({ ...e, status: computeStatus(e.effective_date, now) }));

const imminentCount = rows.filter(
  (r) => r.status.kind === 'imminent' || r.status.kind === 'past'
).length;
const liveCount = rows.filter((r) => r.status.kind === 'past').length;

const canonical = (meta.site_url || 'https://ai-model-change-radar.vercel.app').replace(/\/$/, '');
const desc = meta.tagline;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{meta.title} — LLM deprecation & breaking-change timeline</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical + '/'} />
    <link rel="alternate" type="application/rss+xml" title="AI Model Change Radar — feed" href={canonical + '/rss.xml'} />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical + '/'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' fill='%230a0b0a'/%3E%3Ccircle cx='16' cy='16' r='11' fill='none' stroke='%23ffb000' stroke-width='1.5'/%3E%3Ccircle cx='16' cy='16' r='5' fill='none' stroke='%23ffb000' stroke-width='1.5'/%3E%3Cline x1='16' y1='16' x2='25' y2='9' stroke='%23ff3b1f' stroke-width='2'/%3E%3C/svg%3E" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400&family=Archivo:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --bg: #08090a;
        --bg-panel: #0e1011;
        --bg-row: #0b0d0e;
        --bg-row-alt: #0f1213;
        --ink: #d7dbd4;
        --ink-dim: #7b8378;
        --ink-faint: #525a4f;
        --line: #1d211e;
        --line-bright: #2c322c;
        --amber: #ffb000;
        --amber-dim: #6b5410;
        --red: #ff3b1f;
        --red-bg: #2a0d08;
        --green: #54d66a;
        --grid: rgba(255, 176, 0, 0.022);
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      html { -webkit-text-size-adjust: 100%; }

      body {
        background: var(--bg);
        color: var(--ink);
        font-family: 'JetBrains Mono', ui-monospace, 'SFMono-Regular', Menlo, monospace;
        font-size: 14px;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
        background-image:
          linear-gradient(var(--grid) 1px, transparent 1px),
          linear-gradient(90deg, var(--grid) 1px, transparent 1px);
        background-size: 44px 44px;
        min-height: 100vh;
      }

      a { color: inherit; }

      .wrap {
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 22px;
      }

      /* ---------- masthead ---------- */
      .masthead {
        border-bottom: 1px solid var(--line-bright);
        background:
          linear-gradient(180deg, rgba(255, 176, 0, 0.03), transparent 70%);
        position: relative;
        overflow: hidden;
      }
      .masthead::after {
        content: '';
        position: absolute;
        inset: 0;
        background: repeating-linear-gradient(
          0deg, transparent 0 3px, rgba(0, 0, 0, 0.18) 3px 4px
        );
        pointer-events: none;
        opacity: 0.5;
      }
      .mast-inner {
        padding: 30px 0 26px;
        position: relative;
        z-index: 1;
      }
      .eyebrow {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 11px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--ink-dim);
        margin-bottom: 16px;
      }
      .pulse {
        width: 8px; height: 8px;
        border-radius: 50%;
        background: var(--green);
        box-shadow: 0 0 0 0 rgba(84, 214, 106, 0.6);
        animation: pulse 2.4s infinite;
      }
      @keyframes pulse {
        0% { box-shadow: 0 0 0 0 rgba(84, 214, 106, 0.55); }
        70% { box-shadow: 0 0 0 9px rgba(84, 214, 106, 0); }
        100% { box-shadow: 0 0 0 0 rgba(84, 214, 106, 0); }
      }
      h1 {
        font-family: 'Archivo', sans-serif;
        font-weight: 800;
        font-size: clamp(30px, 5.4vw, 58px);
        line-height: 1.02;
        letter-spacing: -0.02em;
        text-transform: uppercase;
        color: #f3f4ef;
        max-width: 17ch;
      }
      h1 .blink {
        color: var(--amber);
        animation: blink 1.4s steps(1) infinite;
      }
      @keyframes blink { 50% { opacity: 0.15; } }
      .tagline {
        margin-top: 16px;
        max-width: 62ch;
        color: var(--ink-dim);
        font-size: 13.5px;
        line-height: 1.6;
      }

      /* ---------- status strip ---------- */
      .stats {
        display: flex;
        flex-wrap: wrap;
        gap: 0;
        border: 1px solid var(--line-bright);
        border-radius: 2px;
        margin: 26px 0 4px;
        background: var(--bg-panel);
      }
      .stat {
        flex: 1 1 0;
        min-width: 150px;
        padding: 16px 20px;
        border-right: 1px solid var(--line);
      }
      .stat:last-child { border-right: 0; }
      .stat .k {
        font-size: 10.5px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--ink-faint);
        margin-bottom: 7px;
      }
      .stat .v {
        font-family: 'Archivo', sans-serif;
        font-weight: 700;
        font-size: 26px;
        color: var(--ink);
      }
      .stat .v.hot { color: var(--red); }
      .stat .v small {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        font-weight: 400;
        color: var(--ink-dim);
        margin-left: 6px;
      }

      /* ---------- filters ---------- */
      .toolbar {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 10px;
        margin: 30px 0 14px;
      }
      .toolbar .lbl {
        font-size: 11px;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--ink-faint);
        margin-right: 4px;
      }
      .chip {
        font-family: inherit;
        font-size: 12px;
        letter-spacing: 0.04em;
        color: var(--ink-dim);
        background: var(--bg-panel);
        border: 1px solid var(--line-bright);
        border-radius: 2px;
        padding: 7px 13px;
        cursor: pointer;
        transition: border-color 0.12s, color 0.12s, background 0.12s;
        text-transform: uppercase;
      }
      .chip:hover { color: var(--ink); border-color: var(--ink-faint); }
      .chip[aria-pressed='true'] {
        color: var(--bg);
        background: var(--amber);
        border-color: var(--amber);
        font-weight: 700;
      }

      /* ---------- table ---------- */
      .board {
        border: 1px solid var(--line-bright);
        border-radius: 2px;
        overflow: hidden;
        background: var(--bg-panel);
      }
      .thead {
        display: grid;
        grid-template-columns: 132px 1.7fr 1fr 132px;
        gap: 0;
        padding: 11px 20px;
        border-bottom: 1px solid var(--line-bright);
        font-size: 10px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--ink-faint);
        background: #0a0c0d;
      }
      .ev {
        display: grid;
        grid-template-columns: 132px 1.7fr 1fr 132px;
        gap: 0;
        padding: 20px;
        border-bottom: 1px solid var(--line);
        position: relative;
      }
      .ev:nth-child(even) { background: var(--bg-row-alt); }
      .ev:last-child { border-bottom: 0; }
      .ev::before {
        content: '';
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 3px;
        background: var(--ink-faint);
      }
      .ev[data-kind='past']::before { background: var(--ink-faint); }
      .ev[data-kind='imminent']::before { background: var(--red); box-shadow: 0 0 12px rgba(255,59,31,0.55); }
      .ev[data-kind='soon']::before { background: var(--amber); }
      .ev[data-kind='future']::before { background: var(--amber-dim); }

      .col-status { padding-right: 14px; }
      .badge {
        display: inline-block;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 5px 8px;
        border-radius: 2px;
        border: 1px solid;
        line-height: 1.3;
      }
      .badge.past { color: var(--ink-dim); border-color: var(--line-bright); background: #0c0e0f; }
      .badge.imminent { color: #ffd9d0; border-color: var(--red); background: var(--red-bg); }
      .badge.soon { color: var(--amber); border-color: var(--amber-dim); background: #1c1605; }
      .badge.future { color: var(--ink-dim); border-color: var(--line-bright); background: #0c0e0f; }
      .eff-day {
        margin-top: 9px;
        font-size: 11px;
        color: var(--ink-faint);
      }
      .eff-day b { color: var(--ink-dim); font-weight: 500; }

      .col-main { padding-right: 22px; }
      .provider-tag {
        display: inline-block;
        font-size: 10.5px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--amber);
        margin-bottom: 7px;
      }
      .etype {
        font-size: 9.5px;
        color: var(--ink-faint);
        border: 1px solid var(--line-bright);
        padding: 2px 6px;
        border-radius: 2px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-left: 9px;
        vertical-align: 1px;
      }
      .ev-title {
        font-family: 'Archivo', sans-serif;
        font-weight: 700;
        font-size: 16.5px;
        color: #eef0ea;
        line-height: 1.25;
        margin-bottom: 10px;
      }
      .models {
        display: flex;
        flex-wrap: wrap;
        gap: 5px;
        margin-bottom: 11px;
      }
      .mchip {
        font-size: 11px;
        color: var(--ink);
        background: #131617;
        border: 1px solid var(--line-bright);
        border-radius: 2px;
        padding: 3px 7px;
        white-space: nowrap;
      }
      .surface {
        font-size: 10.5px;
        color: var(--ink-faint);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 11px;
      }
      .impact {
        font-size: 12.5px;
        color: var(--ink-dim);
        line-height: 1.55;
        border-left: 2px solid var(--line-bright);
        padding-left: 11px;
      }
      .note {
        font-size: 11.5px;
        color: var(--amber);
        line-height: 1.5;
        margin-top: 10px;
        background: #150f02;
        border: 1px solid var(--amber-dim);
        border-radius: 2px;
        padding: 8px 10px;
      }
      .note::before {
        content: '⚠ ';
        font-weight: 700;
      }

      .col-meta { font-size: 12px; }
      .meta-line {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        padding: 5px 0;
        border-bottom: 1px dotted var(--line);
      }
      .meta-line:last-of-type { border-bottom: 0; }
      .meta-line .mk {
        color: var(--ink-faint);
        text-transform: uppercase;
        font-size: 10px;
        letter-spacing: 0.1em;
        white-space: nowrap;
      }
      .meta-line .mv { color: var(--ink); text-align: right; }
      .repl {
        margin-top: 12px;
        padding: 10px 11px;
        background: #0c1410;
        border: 1px solid #1c3322;
        border-radius: 2px;
      }
      .repl .mk {
        color: var(--green);
        font-size: 9.5px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        display: block;
        margin-bottom: 5px;
      }
      .repl .mv { font-size: 12px; color: var(--ink); line-height: 1.5; }
      .src {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        margin-top: 13px;
        font-size: 11px;
        color: var(--ink-dim);
        text-decoration: none;
        border-bottom: 1px solid var(--line-bright);
        padding-bottom: 2px;
        transition: color 0.12s, border-color 0.12s;
        word-break: break-all;
      }
      .src:hover { color: var(--amber); border-color: var(--amber); }
      .src::before { content: '↗'; color: var(--amber); }

      .empty {
        padding: 50px 20px;
        text-align: center;
        color: var(--ink-faint);
        font-size: 13px;
        display: none;
      }

      /* ---------- footer ---------- */
      footer {
        margin: 56px 0 50px;
        padding-top: 26px;
        border-top: 1px solid var(--line-bright);
        color: var(--ink-faint);
        font-size: 12px;
        line-height: 1.7;
      }
      footer .ver { color: var(--ink-dim); }
      footer .scope { margin-top: 7px; }
      footer a { color: var(--amber); text-decoration: none; border-bottom: 1px solid var(--amber-dim); }
      footer a:hover { border-color: var(--amber); }
      footer .row2 {
        margin-top: 16px;
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        align-items: center;
      }

      @media (max-width: 880px) {
        .thead { display: none; }
        .ev { grid-template-columns: 1fr; gap: 16px; padding: 18px 16px 18px 19px; }
        .col-status { padding-right: 0; }
        .col-main { padding-right: 0; }
        h1 { font-size: clamp(26px, 8vw, 40px); }
        .wrap { padding: 0 14px; }
      }
    </style>
    <!-- Vercel Web Analytics — official @vercel/analytics/astro component
         (pure-static site, no @astrojs/vercel adapter). Its presence in the
         build is what makes Vercel wire the /_vercel/insights/* edge routes. -->
    <Analytics />
  </head>
  <body>
    <header class="masthead">
      <div class="wrap mast-inner">
        <div class="eyebrow">
          <span class="pulse" aria-hidden="true"></span>
          SIGNAL ACTIVE · {meta.providers.join(' / ')}
        </div>
        <h1>AI Model<br />Change Radar<span class="blink">_</span></h1>
        <p class="tagline">{meta.tagline}</p>

        <div class="stats" role="group" aria-label="Summary">
          <div class="stat">
            <div class="k">Tracked events</div>
            <div class="v">{events.length}</div>
          </div>
          <div class="stat">
            <div class="k">Live / past-due</div>
            <div class="v hot">{liveCount}</div>
          </div>
          <div class="stat">
            <div class="k">Imminent (≤14d)+past</div>
            <div class="v">{imminentCount}</div>
          </div>
          <div class="stat">
            <div class="k">Providers watched</div>
            <div class="v">{meta.providers.length}<small>OpenAI · Anthropic · Gemini · xAI</small></div>
          </div>
        </div>
      </div>
    </header>

    <main class="wrap">
      <div class="toolbar" role="group" aria-label="Filter by provider">
        <span class="lbl">Filter</span>
        <button class="chip" data-filter="ALL" aria-pressed="true">All</button>
        {PROVIDERS.map((p) => (
          <button class="chip" data-filter={p} aria-pressed="false">{p}</button>
        ))}
      </div>

      <section class="board" id="board" aria-label="Deprecation timeline (soonest first)">
        <div class="thead">
          <div>Status</div>
          <div>Event</div>
          <div>Migration</div>
          <div>Timeline</div>
        </div>

        {rows.map((e) => (
          <article class="ev" data-kind={e.status.kind} data-provider={e.provider}>
            <div class="col-status">
              <span class={`badge ${e.status.kind}`}>{e.status.label}</span>
              <div class="eff-day">
                effective<br /><b>{fmtDate(e.effective_date)}</b>
              </div>
            </div>

            <div class="col-main">
              <span class="provider-tag">{e.provider}</span>
              <span class="etype">{e.event_type}</span>
              <h2 class="ev-title">{e.title}</h2>
              <div class="models">
                {e.models.map((m) => <span class="mchip">{m}</span>)}
              </div>
              <div class="surface">Surface: {e.surface}</div>
              <p class="impact">{e.impact}</p>
              {e.effective_note && <p class="note">{e.effective_note}</p>}
            </div>

            <div class="col-meta">
              <div class="meta-line">
                <span class="mk">Announced</span>
                <span class="mv">{e.announced_date ? fmtDate(e.announced_date) : 'not stated'}</span>
              </div>
              <div class="meta-line">
                <span class="mk">Effective</span>
                <span class="mv">{fmtDate(e.effective_date)}</span>
              </div>
              <div class="meta-line">
                <span class="mk">Notice</span>
                <span class="mv">{e.notice_days == null ? '—' : `${e.notice_days} days`}</span>
              </div>
              <div class="repl">
                <span class="mk">Recommended replacement</span>
                <span class="mv">{e.replacement}</span>
              </div>
              <a class="src" href={e.source_url} target="_blank" rel="noopener noreferrer">
                {e.source_url.replace(/^https?:\/\//, '')}
              </a>
            </div>
          </article>
        ))}
        <div class="empty" id="empty">No events for this provider.</div>
      </section>

      <footer>
        <div class="ver">v0.1 — manually curated, data reviewed 2026-05-16 · data as of {BUILD_DATE} (build date)</div>
        <div class="scope">Tracks deprecation/shutdown/breaking-change events for OpenAI, Anthropic, Google/Gemini, xAI.</div>
        <div class="row2">
          <a href="/rss.xml">RSS feed →</a>
          <a href="mailto:radar@foundagent.net?subject=Missed%20event">Report a missed event →</a>
        </div>
      </footer>
    </main>

    <script is:inline>
      (function () {
        var chips = document.querySelectorAll('.chip[data-filter]');
        var rows = document.querySelectorAll('.ev[data-provider]');
        var empty = document.getElementById('empty');
        chips.forEach(function (chip) {
          chip.addEventListener('click', function () {
            var f = chip.getAttribute('data-filter');
            chips.forEach(function (c) {
              c.setAttribute('aria-pressed', c === chip ? 'true' : 'false');
            });
            var shown = 0;
            rows.forEach(function (r) {
              var match = f === 'ALL' || r.getAttribute('data-provider') === f;
              r.style.display = match ? '' : 'none';
              if (match) shown++;
            });
            empty.style.display = shown === 0 ? 'block' : 'none';
          });
        });
      })();
    </script>
  </body>
</html>
